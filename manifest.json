{
  "manifest_version": 3,
  "name": "Material Picker",
  "version": "1.0.0",
  "description": "A Chrome extension for picking materials",
  "permissions": ["storage", "identity", "tabs", "scripting", "notifications"],
  "host_permissions": ["<all_urls>", "https://accounts.google.com/*", "https://www.googleapis.com/*"],
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID",
    "scopes": ["https://www.googleapis.com/auth/userinfo.profile", "https://www.googleapis.com/auth/userinfo.email"]
  },
  "action": {
    "default_popup": "pages/popup/index.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/index.js"
  },
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["pages/content/index.js"]
    },
    {
      "matches": ["<all_urls>"],
      "js": ["pages/content/src/chart-detector.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["google-icon.svg", "icon-16.png", "icon-32.png", "icon-48.png", "icon-128.png"],
      "matches": ["<all_urls>"]
    }
  ]
}
